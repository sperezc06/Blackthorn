{
  "name": "saucedemo-qa-challenge",
  "version": "1.0.0",
  "description": "Senior QA Engineer Challenge - SauceDemo E-Commerce Testing",
  "scripts": {
    "test": "bddgen && playwright test",
    "test:ui": "bddgen && playwright test --grep @ui",
    "test:api": "bddgen && playwright test --grep @api",
    "test:demo": "bddgen && VISUAL_DEBUG=1 SLOW_MO=750 playwright test --grep @ui --project=chromium --headed --workers=1",
    "report": "npx monocart show-report monocart-report/index.html"
  },
  "devDependencies": {
    "@playwright/test": "^1.51.0",
    "@types/node": "^22.13.10",
    "allure-commandline": "^2.34.0",
    "allure-playwright": "^3.2.2",
    "monocart-reporter": "^2.12.2",
    "playwright-bdd": "^9.2.0",
    "typescript": "^5.8.2"
  }
}
